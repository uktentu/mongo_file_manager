# ─────────────────────────────────────────────────────────────────────────────
# MongoDB Document Seeder — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.
# All settings are documented with their types, defaults, and accepted values.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Full connection string. For Atlas: mongodb+srv://<user>:<pass>@<cluster>/<db>
# Required. No default in production.
MONGO_URI=mongodb://localhost:27017

# Target database name.
# Default: doc_management
MONGO_DB_NAME=doc_management

# Connection pool size (int, default: 50)
# MONGO_MAX_POOL_SIZE=50

# Connect timeout in milliseconds (int, default: 5000)
# MONGO_CONNECT_TIMEOUT_MS=5000

# Server selection timeout in milliseconds (int, default: 5000)
# MONGO_SERVER_TIMEOUT_MS=5000

# ── API Server ────────────────────────────────────────────────────────────────
# Shared API key for the X-API-Key header. Leave empty to disable auth (dev only).
# Required in ENVIRONMENT=production — startup will fail if unset.
# API_KEY=

# Host and port to bind the server to.
# Default: 0.0.0.0:8000
# API_HOST=0.0.0.0
# API_PORT=8000

# Number of Gunicorn worker processes (int, default: 2)
# API_WORKERS=2

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Log format: text | json
# Use json in production/cloud environments where log aggregators parse structured logs.
# Default: text
LOG_FORMAT=text

# ── Runtime ───────────────────────────────────────────────────────────────────
# Environment name: development | staging | production
# In production: API_KEY is enforced, additional guards may activate.
# Default: development
ENVIRONMENT=development
